# Azure AI Foundry Configuration
AZURE_AI_ENDPOINT=https://<your-project>.api.azureml.ms
AZURE_AI_KEY=<your-api-key>

# Azure Subscription
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=<your-resource-group>

# Azure OpenAI (if using directly)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# Azure AI Search (for Challenge 04 RAG)
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_KEY=<your-search-key>
AZURE_SEARCH_INDEX_NAME=university-faq

# Deployed app endpoint (for Challenge 06)
UNIVERSITY_QA_ENDPOINT=https://<your-endpoint>.<region>.inference.ml.azure.com/score
UNIVERSITY_QA_KEY=<your-endpoint-key>
